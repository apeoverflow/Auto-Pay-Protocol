# Chain: flowEvm | base | baseSepolia
CHAIN=baseSepolia

# Agent wallet private key (must hold USDC + native token for gas)
AGENT_PRIVATE_KEY=0x...

# Service (merchant) wallet address — receives subscription payments
MERCHANT_ADDRESS=0x...

# Service port and URL
SERVICE_PORT=4000
SERVICE_URL=http://localhost:4000

# Bridge example only (agent-with-bridge.js)
# SOURCE_CHAIN_ID=1
# SOURCE_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
