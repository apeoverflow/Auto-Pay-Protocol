# Chain preset — switch everything at once: "flowEvm" or "base"
# This sets RPC_URL, POLICY_MANAGER, and CHECKOUT_URL automatically.
# You can still override any of them individually below.
CHAIN=flowEvm

# Your merchant wallet address (receives USDC payments)
MERCHANT_ADDRESS=0x2B8b9182c1c3A9bEf4a60951D9B7F49420D12B9B

# URL where the AutoPay checkout is running (overrides chain preset)
# CHECKOUT_URL=https://flow.autopayprotocol.com/checkout

# URL where the AutoPay relayer API is running (serves plan metadata)
RELAYER_URL=http://localhost:3420

# Webhook secret (must match what's registered with the relayer)
WEBHOOK_SECRET=test-secret-123

# Override chain preset defaults (optional)
# RPC_URL=https://mainnet.evm.nodes.onflow.org
# POLICY_MANAGER=0x5EDAF928C94A249C5Ce1eaBaD0fE799CD294f345

# Supabase (for tracking subscribers via webhooks)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Server port (default 3002, since relayer uses 3001)
PORT=3002
