# Deployer wallet (required)
PRIVATE_KEY=0x...

# Your address to collect protocol fees - 2.5% (required)
FEE_RECIPIENT=0x...

# Relayer database (for reset-indexer-db command)
# Default: postgres://autopay:password@localhost:5432/autopay (docker-compose)
# DATABASE_URL=postgres://user:pass@host:5432/autopay

# ─── Legacy overrides (only needed if NOT using CHAIN= arg) ───
# When using `make deploy CHAIN=flowEvm`, these are read from chains.json automatically.
# Only set these if you want to deploy without specifying a chain name.
# RPC_URL=https://mainnet.evm.nodes.onflow.org
# USDC_ADDRESS=0xF1815bd50389c46847f0Bda824eC8da914045D14
# CHAIN_NAME=flowEvm
# EXPLORER_URL=https://evm.flowscan.io
# VERIFIER_URL=https://evm.flowscan.io/api/
