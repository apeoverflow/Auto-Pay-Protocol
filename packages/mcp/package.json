{
  "name": "@autopayprotocol/mcp",
  "version": "0.1.2",
  "description": "MCP server for AutoPay Protocol — lets AI agents manage crypto subscriptions via tool calls",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/apeoverflow/Auto-Pay-Protocol.git",
    "directory": "packages/mcp"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "autopay-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run src/__tests__/server.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@autopayprotocol/agent-sdk": "^0.1.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
