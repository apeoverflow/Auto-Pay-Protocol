# Shared secret for webhook signature verification (must match relayer)
WEBHOOK_SECRET=your-webhook-secret

# Checkout URL from merchant dashboard (includes plan, fields, success/cancel URLs)
# CHECKOUT_URL=https://autopayprotocol.com/checkout?merchant=0x...&metadata_url=...&amount=1&interval=604800&fields=name:r,email:r

# Merchant address (defaults to the same as merchant-checkout example)
# MERCHANT_ADDRESS=0x2B8b9182c1c3A9bEf4a60951D9B7F49420D12B9B

# Optional
PORT=4100
CHAIN=baseSepolia
ENTRY_FEE=1
